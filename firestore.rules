rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function canAccessWorkspace(workspaceId) {
      return signedIn()
        && workspaceId in userDoc().data.workspacesPermitidos;
    }

    match /users/{uid} {
      allow read, update: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid;
    }

    match /workspaces/{workspaceId} {
      allow create: if signedIn()
        && request.resource.data.criadoPor == request.auth.uid;
      allow read, update, delete: if canAccessWorkspace(workspaceId);

      match /{collection}/{document} {
        allow read, write: if canAccessWorkspace(workspaceId);
      }
    }
  }
}
